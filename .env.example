# Jobpal — environment variables
# Every integration is OPTIONAL. With none set, the app runs fully on a
# local JSON store + deterministic mock LLM so you can test end-to-end.
# Copy this file to `.env.local` and fill in what you have.

# --- Azure AI Foundry (LLM: CV parsing, JD parsing, resume tailoring) ---
# Without these, a deterministic mock generator is used instead.
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_FOUNDRY_DEPLOYMENT=gpt-4o
AZURE_FOUNDRY_API_VERSION=2024-08-01-preview

# --- Exa (extension contact recommendations) ---
# Used server-side to find relevant recruiters and hiring/team contacts.
EXA_API_KEY=

# --- Supabase (Auth + Postgres DB) ---
# Dashboard → Project Settings → API. Required for real auth + persistence.
# Without these, the app runs single-user on a local .data/ JSON store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (storage for original uploaded resume files) ---
# Without these, uploads are parsed but the original file isn't archived.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# --- Job alerts ---
# Job Alerts scans live public ATS job boards directly — no key required.
# When a scan returns nothing, the feed shows an empty state (no fake jobs).

# --- Google OAuth (Gmail application tracker) ---
# Console: https://console.cloud.google.com — enable the Gmail API, add the
# scope https://www.googleapis.com/auth/gmail.readonly, and set the redirect
# URI to {NEXT_PUBLIC_APP_URL}/api/tracker/callback.
# Required for the tracker — without these, Gmail tracking is shown as
# "coming soon" rather than connecting to fabricated data.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- App ---
# Public base URL (used to build the OAuth redirect + cron links).
NEXT_PUBLIC_APP_URL=http://localhost:3002
# Chrome extension origin for production CORS, e.g.
# chrome-extension://abcdefghijklmnopabcdefghijklmnop
# In local dev, unset allows chrome-extension:// origins for extension API routes.
CHROME_EXTENSION_ORIGIN=
# Shared secret guarding /api/cron/sync-trackers (Vercel Cron sends it as a
# Bearer token). Generate a random string for production.
CRON_SECRET=

# --- Dodo Payments (subscriptions: Free / Pro $9.99 / Premium $19.99) ---
# Dashboard → Developer → API Keys + Webhooks. Without these, billing runs in
# a local "simulate" mode so the full upgrade → welcome flow is testable, and
# every user stays on the Free plan (no real charges possible).
#   • Create two SUBSCRIPTION products (Pro, Premium) and paste their ids below.
#   • Point a webhook at {NEXT_PUBLIC_APP_URL}/api/billing/webhook and subscribe
#     to the subscription.* events; paste its signing secret as the webhook key.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Optional: where Dodo returns the user after checkout. Defaults to
# {NEXT_PUBLIC_APP_URL}/welcome?plan=<plan>.
DODO_PAYMENTS_RETURN_URL=
# Dodo subscription product ids for each paid plan.
DODO_PRODUCT_PRO=
DODO_PRODUCT_PREMIUM=
